<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>EMPRESA - Inmobiliaria</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #C9A84C;
      --dark: #0D1B2A;
      --navy: #1B2A4A;
      --blue: #1E3A6E;
      --accent: #2563EB;
      --white: #FFFFFF;
      --light: #F4F6FA;
      --gray: #6B7280;
      --text: #1F2937;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      background: var(--white);
      overflow-x: hidden;
    }

    /* ─── NAVBAR ─── */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 32px;
      background: var(--white);
      border-bottom: 1px solid #E5E7EB;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 2px;
      color: var(--dark);
    }
    .nav-logo span { color: var(--gold); }
    .nav-icon {
      width: 36px; height: 36px;
      background: var(--gold);
      border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
    }
    .nav-icon svg { fill: white; width: 20px; }
    .nav-right { display: flex; align-items: center; gap: 16px; }
    .nav-right button {
      background: none; border: none; cursor: pointer;
      font-size: 1.1rem; color: var(--gray);
    }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      background: linear-gradient(110deg, #09142a 0%, #0e2348 38%, #122d5c 62%, #0b1e3d 100%);
      min-height: 320px;
      padding: 0 52px;
      display: flex;
      align-items: center;
      overflow: hidden;
      gap: 0;
    }
    /* Noise grain overlay */
    .hero::after {
      content: '';
      position: absolute; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      opacity: 0.4;
    }
    /* Gold glow orb */
    .hero-orb {
      position: absolute;
      width: 420px; height: 420px;
      background: radial-gradient(circle, rgba(201,168,76,0.18) 0%, rgba(201,168,76,0.04) 45%, transparent 70%);
      top: -80px; right: 260px;
      border-radius: 50%;
      pointer-events: none;
    }
    .hero-orb2 {
      position: absolute;
      width: 300px; height: 300px;
      background: radial-gradient(circle, rgba(30,90,180,0.25) 0%, transparent 70%);
      bottom: -60px; left: 30%;
      border-radius: 50%;
      pointer-events: none;
    }

    /* LEFT — text */
    .hero-content {
      flex: 0 0 auto;
      width: 52%;
      z-index: 2;
      padding: 44px 0;
    }
    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(201,168,76,0.15);
      border: 1px solid rgba(201,168,76,0.35);
      color: var(--gold);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 5px 12px;
      border-radius: 30px;
      margin-bottom: 12px;
    }
    .hero h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 5.8rem;
      line-height: 0.95;
      color: var(--white);
      letter-spacing: 1px;
      margin-bottom: 2px;
    }
    .hero h1 .gold-line { color: var(--gold); display: block; }
    .hero-italic {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.15rem;
      color: rgba(255,255,255,0.6);
      margin: 8px 0 20px;
      letter-spacing: 0.3px;
    }

    /* Price badge */
    .hero-price-badge {
      display: inline-flex;
      flex-direction: column;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.14);
      border-left: 3px solid var(--gold);
      border-radius: 8px;
      padding: 10px 18px;
      margin-bottom: 22px;
    }
    .hero-price-badge .label {
      font-size: 0.68rem;
      color: rgba(255,255,255,0.5);
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }
    .hero-price-badge .amount {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.9rem;
      color: var(--gold);
      letter-spacing: 1px;
      line-height: 1.1;
    }

    /* Feature checklist */
    .hero-features {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 7px 28px;
      margin-bottom: 28px;
      list-style: none;
    }
    .hero-features li {
      color: rgba(255,255,255,0.75);
      font-size: 0.8rem;
      display: flex;
      align-items: center;
      gap: 7px;
      font-weight: 400;
    }
    .check-icon {
      width: 16px; height: 16px;
      background: var(--gold);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .check-icon svg { width: 9px; fill: var(--dark); }

    /* CTA row */
    .hero-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    .btn-book {
      background: var(--gold);
      color: var(--dark);
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: 0.82rem;
      padding: 13px 30px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 18px rgba(201,168,76,0.35);
    }
    .btn-book:hover {
      background: #e0b94e;
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(201,168,76,0.45);
    }
    .hero-contact {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .hero-contact a {
      color: rgba(255,255,255,0.55);
      font-size: 0.75rem;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: color 0.2s;
    }
    .hero-contact a:hover { color: var(--gold); }
    .contact-dot {
      width: 4px; height: 4px;
      background: var(--gold);
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* RIGHT — image collage */
    .hero-visual {
      flex: 1;
      position: relative;
      height: 320px;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }
    /* Gold ring decoration */
    .ring {
      position: absolute;
      border-radius: 50%;
      border: 2px solid;
      pointer-events: none;
    }
    .ring-1 {
      width: 220px; height: 220px;
      border-color: rgba(201,168,76,0.5);
      top: 20px; right: 110px;
    }
    .ring-2 {
      width: 160px; height: 160px;
      border-color: rgba(201,168,76,0.2);
      top: 50px; right: 80px;
    }
    /* Logo badge */
    .hero-logo {
      position: absolute;
      top: 18px; right: 12px;
      background: rgba(9,20,42,0.75);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(201,168,76,0.3);
      border-radius: 12px;
      padding: 12px 18px;
      text-align: center;
      z-index: 5;
    }
    .hero-logo .logo-icon {
      font-size: 0;
      line-height: 0;
      margin-bottom: 4px;
    }
    .hero-logo .logo-icon svg {
      width: 32px; fill: var(--gold);
    }
    .hero-logo p {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.95rem;
      letter-spacing: 2px;
      color: var(--white);
      line-height: 1;
    }
    .hero-logo p span { display: block; font-size: 0.65rem; color: rgba(255,255,255,0.45); letter-spacing: 3px; font-family: 'DM Sans', sans-serif; font-weight: 300; }

    /* Photo circles */
    .photo-circle {
      position: absolute;
      border-radius: 50%;
      overflow: hidden;
      border: 3px solid rgba(255,255,255,0.12);
      background: linear-gradient(135deg, #1b3f7c 0%, #0a1f44 100%);
      display: flex; align-items: center; justify-content: center;
    }
    .photo-main {
      width: 185px; height: 185px;
      top: 26px; left: 20px;
      border-color: rgba(201,168,76,0.4);
      font-size: 4.5rem;
    }
    .photo-sm1 {
      width: 110px; height: 110px;
      bottom: 18px; left: 0;
      font-size: 2.6rem;
    }
    .photo-sm2 {
      width: 115px; height: 115px;
      bottom: 12px; right: 140px;
      font-size: 2.6rem;
    }
    /* Arrow nav */
    .hero-arrow {
      position: absolute;
      right: 0; top: 50%;
      transform: translateY(-50%);
      width: 32px; height: 32px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: rgba(255,255,255,0.6);
      font-size: 1rem;
      cursor: pointer;
      z-index: 6;
    }

    /* ─── SECTION HEADERS ─── */
    .section { padding: 64px 48px; }
    .section-center { text-align: center; }
    .section h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.6rem;
      letter-spacing: 1px;
      color: var(--dark);
      margin-bottom: 8px;
    }
    .section-sub {
      color: var(--gray);
      font-size: 0.9rem;
      max-width: 480px;
      margin: 0 auto 40px;
      line-height: 1.6;
    }

    /* ─── PROPERTY CARDS ─── */
    .props-wrapper {
      position: relative;
      background: var(--light);
    }
    .props-carousel {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      max-width: 1100px;
      margin: 0 auto;
    }
    .prop-card {
      background: var(--white);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 16px rgba(0,0,0,0.07);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .prop-card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0,0,0,0.13); }
    .prop-img {
      width: 100%; height: 180px;
      background: linear-gradient(135deg, #1e3a6e 0%, #0d2040 100%);
      display: flex; align-items: center; justify-content: center;
      font-size: 3rem;
      position: relative;
      overflow: hidden;
    }
    .prop-img::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.3));
    }
    .prop-body { padding: 16px; }
    .prop-title { font-weight: 600; font-size: 0.95rem; margin-bottom: 6px; }
    .prop-desc { color: var(--gray); font-size: 0.8rem; line-height: 1.5; margin-bottom: 14px; }
    .prop-footer { display: flex; align-items: center; justify-content: space-between; }
    .prop-price { font-weight: 700; font-size: 1.05rem; color: var(--dark); }
    .prop-price span { font-size: 0.75rem; color: var(--gray); font-weight: 400; }
    .btn-detail {
      background: var(--dark);
      color: var(--white);
      font-size: 0.78rem;
      font-weight: 600;
      padding: 8px 16px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-detail:hover { background: var(--blue); }
    .carousel-arrow {
      position: absolute;
      top: 50%; transform: translateY(-50%);
      background: var(--white);
      border: 1px solid #E5E7EB;
      border-radius: 50%;
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      font-size: 1rem;
      color: var(--gray);
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      z-index: 5;
    }
    .carousel-arrow.left { left: 8px; }
    .carousel-arrow.right { right: 8px; }

    /* ─── PROMO BANNER ─── */
    .promo-banner {
      background: linear-gradient(135deg, var(--dark) 0%, var(--navy) 50%, #0F3460 100%);
      padding: 56px 64px;
      display: flex;
      align-items: center;
      gap: 48px;
      overflow: hidden;
      position: relative;
    }
    .promo-banner::before {
      content: '';
      position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .promo-text { flex: 1; z-index: 1; }
    .promo-text h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 4rem;
      color: var(--white);
      line-height: 0.95;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .promo-text h2 em { color: var(--gold); font-style: normal; }
    .promo-text p {
      color: rgba(255,255,255,0.7);
      margin: 14px 0 24px;
      font-size: 0.9rem;
      line-height: 1.6;
      max-width: 360px;
    }
    .btn-promo {
      background: var(--accent);
      color: var(--white);
      font-weight: 700;
      font-size: 0.88rem;
      padding: 12px 28px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-promo:hover { background: #1d4ed8; transform: translateY(-1px); }
    .promo-image {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
    }
    .promo-shoe {
      font-size: 8rem;
      filter: drop-shadow(0 20px 40px rgba(0,0,0,0.5));
      transform: rotate(-20deg);
      line-height: 1;
    }
    .promo-circle {
      position: absolute;
      width: 260px; height: 260px;
      background: radial-gradient(circle, rgba(37,99,235,0.3), transparent 70%);
      border-radius: 50%;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
    }

    /* ─── TESTIMONIALS ─── */
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      max-width: 1100px;
      margin: 0 auto;
    }
    .testi-card {
      position: relative;
      border-radius: 12px;
      overflow: hidden;
      cursor: pointer;
      aspect-ratio: 3/4;
      background: linear-gradient(160deg, #1a3a6a 0%, #0d2040 100%);
    }
    .testi-card:nth-child(2) { background: linear-gradient(160deg, #2d4a7a, #1a3050); }
    .testi-card:nth-child(3) { background: linear-gradient(160deg, #4a3520, #2d2010); }
    .testi-card:nth-child(4) { background: linear-gradient(160deg, #1a3a6a, #0d304a); }
    .testi-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
    }
    .testi-avatar {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      font-size: 4rem;
    }
    .testi-bottom {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 14px;
    }
    .testi-stars { color: var(--gold); font-size: 0.7rem; margin-bottom: 4px; }
    .testi-link {
      display: flex; align-items: center; gap: 6px;
      color: rgba(255,255,255,0.85);
      font-size: 0.75rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .testi-link::before { content: '▶'; font-size: 0.6rem; }

    /* ─── STATS ─── */
    .stats {
      padding: 56px 48px;
      display: flex;
      justify-content: center;
      gap: 96px;
      background: var(--white);
    }
    .stat-item { text-align: center; }
    .stat-number {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      color: var(--accent);
      line-height: 1;
    }
    .stat-label {
      font-size: 0.8rem;
      color: var(--gray);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: 6px;
    }

    /* ─── FAQ ─── */
    .faq-section {
      background: var(--light);
      padding: 64px 48px;
    }
    .faq-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      max-width: 1100px;
      margin: 0 auto;
      align-items: start;
    }
    .faq-left h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.4rem;
      letter-spacing: 1px;
      margin-bottom: 28px;
    }
    .faq-item {
      border-bottom: 1px solid #D1D5DB;
      padding: 16px 0;
    }
    .faq-question {
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text);
      gap: 16px;
    }
    .faq-chevron {
      color: var(--gray);
      font-size: 1rem;
      transition: transform 0.25s;
      flex-shrink: 0;
    }
    .faq-item.open .faq-chevron { transform: rotate(180deg); }
    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease, padding 0.2s;
      font-size: 0.85rem;
      color: var(--gray);
      line-height: 1.7;
    }
    .faq-item.open .faq-answer {
      max-height: 200px;
      padding-top: 12px;
    }
    .faq-image {
      border-radius: 14px;
      overflow: hidden;
      background: linear-gradient(135deg, #1e3a6e, #0d2040);
      height: 340px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .faq-image-inner {
      font-size: 5rem;
      z-index: 1;
    }
    .faq-badge {
      position: absolute;
      top: 20px; left: 20px;
      background: rgba(255,255,255,0.12);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 10px;
      padding: 10px 16px;
      color: var(--white);
      font-size: 0.8rem;
      font-weight: 600;
      display: flex; align-items: center; gap: 8px;
    }
    .faq-badge span { color: var(--gold); }

    /* ─── CONTACT ─── */
    .contact-section {
      padding: 64px 48px;
      text-align: center;
    }
    .contact-section h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.6rem;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }
    .contact-form {
      max-width: 700px;
      margin: 40px auto 0;
      text-align: left;
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 20px;
    }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group.full { grid-column: 1 / -1; }
    label {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--text);
    }
    input, textarea {
      border: 1px solid #D1D5DB;
      border-radius: 8px;
      padding: 12px 14px;
      font-size: 0.88rem;
      font-family: 'Outfit', sans-serif;
      color: var(--text);
      background: var(--white);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      width: 100%;
    }
    input::placeholder, textarea::placeholder { color: #9CA3AF; }
    input:focus, textarea:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
    }
    textarea { resize: vertical; min-height: 110px; }
    .btn-submit {
      width: 100%;
      background: var(--dark);
      color: var(--white);
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      padding: 16px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      margin-top: 8px;
      letter-spacing: 0.5px;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-submit:hover { background: var(--blue); transform: translateY(-1px); }

    /* ─── FOOTER ─── */
    footer {
      text-align: center;
      padding: 20px;
      font-size: 0.78rem;
      color: var(--gray);
      border-top: 1px solid #E5E7EB;
    }

    /* Responsive */
    @media (max-width: 900px) {
      .hero { flex-direction: column; gap: 32px; padding: 36px 24px; }
      .hero h1 { font-size: 2.4rem; }
      .hero-images { width: 100%; height: 180px; }
      .props-carousel { grid-template-columns: 1fr; }
      .testimonials-grid { grid-template-columns: repeat(2, 1fr); }
      .stats { gap: 40px; }
